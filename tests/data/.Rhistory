# Paramètres
obs = 500
c = 0.15
a = 0.04
mu = 0
sigma = 1
alpha = 0.15 # alpha>0
phi = 0.01 # -1<phi<1
# Simulation et Ecriture Matricielle
z = rnorm(n=obs, mean=mu, sd=1)
h = matrix(0, obs, 1)
eps = matrix(0, obs, 1)
y = numeric(obs)
# Observation à la date t = 1
h[1] = c/c(1-a)
eps[1] = mean(z)*sqrt(h[1])
y[1] = alpha/(1-alpha)
# Itération
for (t in 2:obs){
h[t] = c +a*eps[t-1]**2
eps[t] = sqrt(h[t])*z[t] # AR(1)
y[t] = alpha + phi*y[t-1] + eps[t]
}
par(mfrow=c(2,1))
ts.plot(h, main="residual with heteroscedasticity")
ts.plot(y, main="AR(1) process")
