# Paramètres
obs = 1500
c = 0.02
a = 0.10 # a + b < 1 (choc très persistant lorsque a est très faible)
b = 0.84
mu = 0
sigma = 1
alpha = 0.01 # alpha>0
phi = 0.01 # -1<phi<1
# Simulation et Ecriture Matricielle
z = rnorm(n=obs, mean=mu, sd=1)
h = matrix(0, obs, 1)
eps = matrix(0, obs, 1)
y = numeric(obs)
# Observation à la date t = 1
h[1] = c/c(1-a)
eps[1] = mean(z)*sqrt(h[1])
y[1] = alpha/(1-alpha)
# Itération
for (t in 2:obs){
if (a+b < 1){
h[t] = c +a*eps[t-1]**2 + b * h[t-1]
eps[t] = sqrt(h[t])*z[t] # AR(1)
y[t] = alpha + phi*y[t-1] + eps[t]
}
else {
print("Le processus n'est pas stationnaire")
}
}
par(mfrow=c(2,1))
ts.plot(h[c(1000:1500)], main="residual with heteroscedasticity")
ts.plot(y[c(1000:1500)], main="AR(1) process")
fct_garch_simulation <-  function(obs, c, a, b, mu, sigma, alpha, phi, start, end){
# Objectif : Fonction pour simuler un processus GARCH
# Simulation de la loi du residu
z = rnorm(n=obs, mean=mu, sd=sigma)
# Ecriture matricielle des fonctions
h = matrix(0, obs, 1)
eps = matrix(0, obs, 1)
y = numeric(obs)
# Initialisation des fonctions à la date t=1
h[1] = c/c(1-a)
eps[1] = mean(z)*sqrt(h[1])
y[1] = alpha/(1-alpha)
# Itération
for (t in 2:obs){
h[t] = c +a*eps[t-1]**2 + b * h[t-1]
eps[t] = sqrt(h[t])*z[t] # AR(1)
y[t] = alpha + phi*y[t-1] + eps[t]
}
return(list("h"=h, "y"=y, "eps"=eps))
# par(mfrow=c(2,1))
# ts.plot(h[c(start:end)], main="residual with heteroscedasticity")
# ts.plot(y[c(start:end)], main="AR(1) process")
}
# Paramètres
params_obs = 1500
params_c = 0.02
params_a = 0.10 # a + b < 1 (choc très persistant lorsque a est très faible)
params_b = 0.84
params_mu = 0
params_sigma = 1
params_alpha = 0.01 # alpha>0
params_phi = 0.01 # -1<phi<1
H_Y_Simulated <- fct_garch_simulation(
obs = params_obs,
c = params_c,
a = params_a,
b = params_b,
mu = params_mu,
sigma = params_sigma,
alpha = params_alpha,
phi = params_phi,
start = 1000,
end = 1500
)
h_simulated <- H_Y_Simulated["h"]$h
y_simulated <- H_Y_Simulated["y"]$y
eps_simulated <- H_Y_Simulated["eps"]$eps
par(mfrow=c(3,1))
ts.plot(h_simulated, main="residual with heteroscedasticity")
ts.plot(y_simulated, main="AR(1) process")
ts.plot(eps_simulated, main="eps process")
qqnorm(eps_simulated)
qqline(eps_simulated, col="red")
