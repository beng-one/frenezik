library(stargazer)
library(xtable)
# Aide
help(package="ridge")
# Chargement de la base de données
data <- read.csv('results_data/data_train.csv')
View(data)
# Régression Ridge
RegRidge <- linearRidge(y ~ ., data = data, lambda = 0.15, scaling = 'scale')
RidgeSummary <- summary(RegRidge)
